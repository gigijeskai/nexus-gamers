// =============================================================================
// Nexus — schema.prisma (Prisma 7)
// Le URL di connessione vanno in prisma.config.ts, NON qui
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatusType {
  ONLINE
  OFFLINE
  IN_GAME
  AWAY

  @@map("user_status_type")
}

enum Platform {
  STEAM
  PLAYSTATION
  XBOX
  RIOT
  EPIC
  BATTLENET
  NINTENDO
  EA
  UBISOFT

  @@map("platform")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED

  @@map("friendship_status")
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  FRIEND_ONLINE
  FRIEND_IN_GAME
  NEW_MESSAGE

  @@map("notification_type")
}

// =============================================================================
// MODELS
// =============================================================================

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  name          String?
  image         String?
  username      String?  @unique
  nexusTag      String?  @unique @map("nexus_tag")
  avatarUrl     String?  @map("avatar_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // Nexus relations
  status         UserStatus?
  gameIdentities GameIdentity[]
  notifications  Notification[]

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  sentFriendships     Friendship[] @relation("FriendshipRequester")
  receivedFriendships Friendship[] @relation("FriendshipAddressee")

  @@map("users")
}


model UserStatus {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @unique @map("user_id") @db.Uuid
  status      UserStatusType @default(OFFLINE)
  currentGame String?        @map("current_game")
  lastSeen    DateTime       @default(now()) @map("last_seen")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_status")
}

model GameIdentity {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  platform         Platform
  platformUsername String   @map("platform_username")
  platformId       String?  @map("platform_id")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("game_identities")
}

model Friendship {
  id          String           @id @default(uuid()) @db.Uuid
  requesterId String           @map("requester_id") @db.Uuid
  addresseeId String           @map("addressee_id") @db.Uuid
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@map("friendships")
}

model Message {
  id         String   @id @default(uuid()) @db.Uuid
  senderId   String   @map("sender_id") @db.Uuid
  receiverId String   @map("receiver_id") @db.Uuid
  content    String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, senderId, createdAt])
  @@map("messages")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  payload   Json             @default("{}")
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// =============================================================================
// BETTER AUTH — Required models
// =============================================================================

model Session {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("better_auth_sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String    @db.Uuid @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @db.Text @map("access_token")
  refreshToken          String?   @db.Text @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @db.Text @map("id_token")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("better_auth_accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("better_auth_verifications")
}
